# MongoDB must be a REPLICA SET — transactions (the booking guard) require it.
# Local: `docker compose up -d` gives a single-node rs0.
DATABASE_URL=mongodb://127.0.0.1:27017/clinic-management?replicaSet=rs0

# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000
